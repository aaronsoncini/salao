<!-- ========================= HERO ========================= -->
<header class="hero" id="inicio">
    <img src="/imgs/FOTO INICIO.png" alt="Banner" class="banner-inicio">
    <div class="box-inicio">
        <h1 class="ttl-inicio">
            SUA COROA, SUA HISTÓRIA,<br>SUAS TRANÇAS.
        </h1>
        <br>
        <h2 class="subttl-inicio">
            Vem realçar sua beleza com a gente.<br>Agende seu horário.
        </h2>
        <a href="/agendar">
            <button class="btn-inicio">
                <img src="/imgs/ICONE WHATSAPP.png" alt="" class="icone-whats">
                Agendamentos
            </button>
        </a>
    </div>
</header>

<!-- ========================= QUEM SOMOS ========================= -->
<section class="quemSomos" id="quemsomos">
    <div class="superior">
        <img src="/imgs/QUEM_SOMOS_-removebg-preview.png" alt="Quem Somos" class="bannerQuemSomossup">
        <div class="boxText">
            <h1 class="ttl-text">QUEM SOMOS?</h1>
            <h2 class="text">
                Prazer, eu sou a Kakau, idealizadora, mente criativa e responsável por cada detalhe do Trançadeira
                Odaras.<br><br>
                Mais do que um salão, somos um espaço de valorização da beleza, da cultura e da identidade através
                das tranças. Também compartilhamos conhecimento por meio dos nossos cursos, onde ensinamos
                diferentes técnicas para quem deseja aprender, se aperfeiçoar e arrasar no universo das tranças.
            </h2>
        </div>
        <img src="/imgs/QUEM_SOMOS_-removebg-preview.png" alt="Quem Somos" class="bannerQuemSomossup2">
    </div>
    <div class="inferior">
        <div class="boxText">
            <h1 class="ttl-text">ESPAÇO ACONCHEGANTE</h1>
            <h2 class="text">
                Nosso espaço é simples, acolhedor e pensado com carinho para receber você.<br><br>
                Em um ambiente mais intimista, cada cliente é atendido com atenção, conforto e cuidado, como se
                estivesse em casa. Aqui, você não é só mais um atendimento — você é bem-vinda, respeitada e
                valorizada em cada detalhe.
            </h2>
        </div>
        <img src="/imgs/ESPAÇOaCONCHEGANTE.png" alt="Espaço Aconchegante" class="bannerQuemSomosinf">
    </div>
</section>

<!-- ========================= NOSSAS TRANÇAS ========================= -->
<section class="trancas" id="trancas">
    <div id="slider" class="splide">
        <h1 class="ttl-trancas">NOSSAS TRANÇAS</h1>
        <div class="splide__track">
            <ul class="splide__list">
                <li class="splide__slide slide-1">
                    <div class="card-tranca">
                        <div class="box-text">
                            <h1 class="ttl-card">GHANA BRAIDS</h1>
                            <p class="text-card">Tranças rentes ao couro cabeludo, feitas com alongamento progressivo, criando um efeito marcante e elegante.</p>
                        </div>
                    </div>
                </li>
                <li class="splide__slide slide-2">
                    <div class="card-tranca">
                        <div class="box-text">
                            <h1 class="ttl-card">CROCHÊ BRAID</h1>
                            <p class="text-card">Técnica prática onde os fios são aplicados com agulha de crochê sobre o cabelo trançado, garantindo volume e versatilidade.</p>
                        </div>
                    </div>
                </li>
                <li class="splide__slide slide-3">
                    <div class="card-tranca">
                        <div class="box-text">
                            <h1 class="ttl-card">BOX BRAIDS</h1>
                            <p class="text-card">Tranças soltas feitas em mechas quadradas, ideais para quem busca estilo, proteção e durabilidade.</p>
                        </div>
                    </div>
                </li>
                <li class="splide__slide slide-4">
                    <div class="card-tranca">
                        <div class="box-text">
                            <h1 class="ttl-card">FRENCH CURL BRAIDS</h1>
                            <p class="text-card">Tranças com pontas cacheadas e acabamento mais leve, trazendo um visual moderno e sofisticado.</p>
                        </div>
                    </div>
                </li>
            </ul>
        </div>
        <h2 class="ttl-tracasBase">
            Os valores variam conforme tamanho, comprimento, volume e estilo desejado.<br>
            Entre em contato com a gente para um orçamento personalizado.
        </h2>
        <div class="boxRede">
            <a href="#"><img class="icone" src="/imgs/ICONE WHATSAPP.png" alt="WhatsApp"></a>
            <a href="#"><img class="icone" src="/imgs/iconeIsta.png" alt="Instagram"></a>
        </div>
    </div>
</section>

<!-- ========================= DEPOIMENTOS ========================= -->
<section class="depoimetos" id="depoimentos">
    <div id="meuSlider" class="splide">
        <div class="splide__track">
            <ul class="splide__list">
                <li class="splide__slide">
                    <div class="card">
                        <h1 class="aspas">"</h1>
                        <h1 class="aspasInf">"</h1>
                        <p class="text-depoimentos">
                            Bom dia, tudo bem?<br>
                            Quero agradecer a todo o seu trabalho e dedicação durante os sete anos cuidando do meu
                            "TUIMMM". Dizem que o cabelo é capaz de mudar por completo a aparência de uma pessoa. Se
                            hoje já me acostumei com o meu cabelo, muitas pessoas me elogiaram devido a ter assumido meu cabelo natural.
                        </p>
                    </div>
                </li>
                <li class="splide__slide">
                    <div class="card2">
                        <h1 class="aspas">"</h1>
                        <h1 class="aspasInf">"</h1>
                        <p class="text-depoimentos">
                            Se eu quero liso ela faz, se eu quero curto ela faz, se quero encaracolado ela faz,
                            se for comprido ela faz ou ondulado. Amo mudar!!!
                            Né Kakau Teles... obrigada sua linda!!!!
                        </p>
                    </div>
                </li>
                <li class="splide__slide">
                    <div class="card">
                        <h1 class="aspas">"</h1>
                        <h1 class="aspasInf">"</h1>
                        <p class="text-depoimentos">
                            Vim agradecer de ontem, tava na correria e não consegui...
                            Eu amei muito a trança, fiquei outra pessoa kkk todos no trampo amaram.
                            Muito profissional. Grata, e voltarei mais vezes.
                        </p>
                    </div>
                </li>
            </ul>
        </div>
    </div>
    <img src="/imgs/GRAFISMO ONÇA.png" alt="" class="textura">
</section>

<!-- ========================= LOCAL ========================= -->
<section class="local" id="local">
    <h1 class="ttl-local">Onde Estamos & Agende Seu Horário</h1>
    <div class="boxtext-local">
        <img src="/imgs/Subtract.png" alt="" class="iconeLocal">
        <h1 class="subttl-local">R. Biri, 283 - Itaquera</h1>
    </div>
    <div class="box-local">
        <a href="https://www.google.com/maps/place/R.+Biri,+283+-+Itaquera,+S%C3%A3o+Paulo" target="_blank">
            <img src="/imgs/GOOGLE MAPS.png" alt="Google Maps" class="img-local">
        </a>
        <div class="horarios">
            <h2 class="horario">Terça-Feira<br>8:00h às 19:00h</h2>
            <h2 class="horario">Quarta-Feira<br>8:00h às 19:00h</h2>
            <h2 class="horario">Quinta-Feira<br>8:00h às 19:00h</h2>
            <h2 class="horario">Sexta-Feira<br>8:00h às 19:00h</h2>
            <h2 class="horario">Sábado<br>10:00h às 20:00h</h2>
        </div>
        <a href="/agendar">
            <button class="agendamento-local">Agende seu Horário!</button>
        </a>
    </div>
    <img src="/imgs/textura2.png" alt="" class="textura">
</section>

<%- include('partials/footer.ejs') %>

<!-- SPLIDE JS -->
<script src="https://cdn.jsdelivr.net/npm/@splidejs/splide@latest/dist/js/splide.min.js"></script>
<script>
    // Carrossel de Tranças
    document.addEventListener('DOMContentLoaded', function () {
        new Splide('#slider', {
            type: 'loop',
            perPage: 4,
            perMove: 1,
            autoplay: true,
            interval: 3000,
            pauseOnHover: true,
            pagination: true,
            breakpoints: {
                1200: { perPage: 3 },
                900: { perPage: 2 },
                600: { perPage: 1 }
            }
        }).mount();

        // Carrossel de Depoimentos
        new Splide('#meuSlider', {
            type: 'loop',
            perPage: 3,
            perMove: 1,
            autoplay: true,
            interval: 2500,
            gap: 20,
            breakpoints: {
                1024: { perPage: 2 },
                768: { perPage: 1 }
            }
        }).mount();
    });

    // Toggle texto das tranças ao clicar
    var textBox = document.querySelectorAll('.box-text');
    function aparecerFoto(idx) {
        let el = textBox[idx];
        if (el) {
            el.style.opacity = el.style.opacity === '0' ? '1' : '0';
        }
    }
</script>
