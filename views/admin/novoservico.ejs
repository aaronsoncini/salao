<%- include('../partials/header.ejs') %>
<%- include('../partials/navbar.ejs') %>

<div class="page-wrapper">
    <div class="page-header">
        <h1>Gerenciar Serviços</h1>
        <p class="subtitle">Cadastre e visualize os serviços oferecidos</p>
    </div>
    <div class="container">
        <div class="admin-nav">
            <a href="/admin/agendamentos" class="btn btn-outline">📋 Agendamentos</a>
            <a href="/admin/ganhos" class="btn btn-outline">💰 Ganhos</a>
        </div>
        <div class="card">
            <h2>Cadastrar Novo Serviço</h2>
            <form method="post" action="/admin/salvarservico">
                <div class="form-group">
                    <div class="form-row">
                        <div class="form-field">
                            <label for="nome">Nome do Serviço</label>
                            <input type="text" id="nome" name="nome" placeholder="Ex: Trança Box" required>
                        </div>
                        <div class="form-field">
                            <label for="valor">Valor em centavos (ex: 5000 = R$ 50,00)</label>
                            <input type="number" id="valor" name="valor" inputmode="numeric" placeholder="5000" required min="0">
                        </div>
                    </div>
                    <button type="submit" class="btn btn-primary">✔ Cadastrar Serviço</button>
                </div>
            </form>
        </div>
        <div class="card">
            <h2>Serviços Cadastrados</h2>
            <% if (servicos.length === 0) { %>
                <div class="empty-state"><div class="empty-icon">✂️</div><p>Nenhum serviço cadastrado ainda.</p></div>
            <% } else { %>
                <div class="servicos-grid">
                    <% servicos.forEach(servico => { %>
                    <div class="servico-card">
                        <div class="nome-servico"><%= servico.nomeServico %></div>
                        <div class="valor-servico"><%= (servico.valorServico / 100).toFixed(2).replace('.',',') %></div>
                        <div class="valor-label">Valor em reais</div>
                        <div style="margin-top:14px;">
                            <form method="post" action="/admin/deletarservico">
                                <input type="hidden" name="id" value="<%= servico.id %>">
                                <button type="submit" class="btn-danger" onclick="return confirm('Deseja excluir <%= servico.nomeServico %>?')">🗑 Excluir</button>
                            </form>
                        </div>
                    </div>
                    <% }) %>
                </div>
            <% } %>
        </div>
    </div>
</div>

<%- include('../partials/footer.ejs') %>
