<%- include('../partials/header.ejs') %>
<%- include('../partials/navbar.ejs') %>

<div class="page-wrapper">
    <div class="page-header">
        <h1>Área Administrativa</h1>
        <p class="subtitle">Acesso restrito — faça login para continuar</p>
    </div>

    <div class="container" style="max-width:420px;">
        <div class="card">
            <h2>🔐 Login</h2>

            <% if (typeof erro !== 'undefined' && erro) { %>
            <div class="alert" style="background:rgba(192,57,43,0.12);border:1px solid rgba(192,57,43,0.4);color:#e74c3c;margin-bottom:20px;padding:12px 16px;border-radius:8px;font-size:14px;font-weight:600;">
                ❌ <%= erro %>
            </div>
            <% } %>

            <form method="POST" action="/admin/login">
                <div class="form-group">
                    <div class="form-field">
                        <label for="usuario">Usuário</label>
                        <input type="text" id="usuario" name="usuario" placeholder="Digite seu usuário" required autofocus>
                    </div>
                    <div class="form-field">
                        <label for="senha">Senha</label>
                        <input type="password" id="senha" name="senha" placeholder="Digite sua senha" required>
                    </div>
                    <button type="submit" class="btn btn-primary btn-full" style="margin-top:8px;">Entrar</button>
                </div>
            </form>
        </div>
    </div>
</div>

<%- include('../partials/footer.ejs') %>
